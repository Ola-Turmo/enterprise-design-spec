#!/usr/bin/env sh
# Pre-commit hook: auto-validate token files before commit
# Part of enterprise-design-spec

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "🔍 Running enterprise-design-spec pre-commit hook..."
echo ""

# Get root directory (works for monorepos with examples/*)
ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR" || exit 1

# Check if npm/node available
if ! command -v node > /dev/null 2>&1; then
  echo "${YELLOW}⚠️  Node.js not found — skipping token validation${NC}"
  exit 0
fi

# Detect changed token files
TOKEN_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.tokens\.json$|tokens/' | tr '\n' ' ')

# If no token files changed, skip validation
if [ -z "$TOKEN_FILES" ]; then
  echo "${GREEN}✅ No token files changed — skipping validation${NC}"
  exit 0
fi

echo "📁 Token files staged:"
echo "$TOKEN_FILES" | tr ' ' '\n' | while read -r f; do
  echo "   - $f"
done
echo ""

# Run validation
echo "🔎 Validating token schemas..."
FAILED=0

for token_file in $TOKEN_FILES; do
  if [ -f "$token_file" ]; then
    # Quick JSON syntax check
    if ! node -e "JSON.parse(require('fs').readFileSync('$token_file', 'utf8'))" 2>/dev/null; then
      echo "${RED}❌ Invalid JSON: $token_file${NC}"
      FAILED=1
    fi
  fi
done

# Run full validation if jsons are valid
if [ $FAILED -eq 0 ]; then
  # Try full CLI validation
  if [ -f "src/cli.ts" ] && [ -d "node_modules" ]; then
    echo ""
    echo "📋 Running full token validation..."
    if ! npx tsx src/cli.ts validate 2>&1 | tee /tmp/token-validate-output.txt; then
      echo ""
      echo "${RED}❌ Token validation failed — commit aborted${NC}"
      echo ""
      echo "${YELLOW}💡 Fix the issues above, then stage the fixed files and commit again${NC}"
      exit 1
    else
      echo ""
      echo "${GREEN}✅ Token validation passed${NC}"
    fi

    # Run alias check
    echo ""
    echo "🔗 Checking alias references..."
    if ! npx tsx src/cli.ts aliases 2>&1 | tee /tmp/token-alias-output.txt; then
      echo ""
      echo "${RED}❌ Broken alias references found — commit aborted${NC}"
      exit 1
    else
      echo "${GREEN}✅ All aliases resolve correctly${NC}"
    fi
  else
    echo "${YELLOW}⚠️  CLI not found — skipping full validation (run 'npm install' first)${NC}"
  fi
fi

echo ""
echo "${GREEN}✅ Pre-commit hook passed — proceed with commit${NC}"
echo ""
