{
  "theme": {
    "light": {
      "color": {
        "surface": {
          "default": { "$type": "color", "$value": "{color.white}" },
          "subtle": { "$type": "color", "$value": "{color.slate.50}" }
        },
        "text": {
          "default": { "$type": "color", "$value": "{color.text.primary}" },
          "secondary": { "$type": "color", "$value": "{color.text.secondary}" }
        },
        "background": {
          "default": { "$type": "color", "$value": "{color.background.canvas.default}" },
          "surface": { "$type": "color", "$value": "{color.background.surface.default}" }
        }
      }
    }
  }
